# Port the HTTP server listens on
PORT=3000

# Absolute or relative path to the log file being watched
LOG_FILE_PATH=./logs/sample.log

# Number of lines to show on initial page load
TAIL_LINES=10

# Chunk size (in bytes) used when scanning backwards for last-N-lines
# 4096 (4 KB) is a good default; increase for very long average line lengths
READ_CHUNK_SIZE=4096

# How often (ms) to poll for file changes as a fallback when fs.watch is unreliable
# Set to 0 to disable polling fallback (pure fs.watch only)
POLL_INTERVAL_MS=1000
